        -- Создаем временную таблицу для всех данных
        DROP TABLE IF EXISTS tmp_food_details;
        CREATE TABLE tmp_food_details AS
        WITH foods AS (
            SELECT 
                row_number() OVER () as food_id,
                unnest(xpath('//food', xml_data::xml)) as food
            FROM raw_xml
        )
        SELECT 
            food_id,
            (xpath('./name/text()', food))[1]::text as food_name,
            (xpath('./mfr/text()', food))[1]::text as manufacturer,
            (xpath('./serving/text()', food))[1]::text as serving_size,
            (xpath('./serving/@units', food))[1]::text as serving_units,
            (xpath('./calories/@total', food))[1]::text as calories_total,
            (xpath('./calories/@fat', food))[1]::text as calories_fat,
            (xpath('./total-fat/text()', food))[1]::text as total_fat,
            (xpath('./saturated-fat/text()', food))[1]::text as saturated_fat,
            (xpath('./cholesterol/text()', food))[1]::text as cholesterol,
            (xpath('./sodium/text()', food))[1]::text as sodium,
            (xpath('./carb/text()', food))[1]::text as carb,
            (xpath('./fiber/text()', food))[1]::text as fiber,
            (xpath('./protein/text()', food))[1]::text as protein,
            -- Витамины (вложенные элементы)
            (xpath('./vitamins/a/text()', food))[1]::text as vitamin_a,
            (xpath('./vitamins/c/text()', food))[1]::text as vitamin_c,
            -- Минералы (вложенные элементы)
            (xpath('./minerals/ca/text()', food))[1]::text as calcium,
            (xpath('./minerals/fe/text()', food))[1]::text as iron
        FROM foods;
        
        -- Вставляем в основную таблицу
        TRUNCATE TABLE flat_foods;
        INSERT INTO flat_foods (
            food_name, manufacturer, serving_size,
            calories_total, calories_fat,
            total_fat, saturated_fat, cholesterol, sodium,
            carb, fiber, protein,
            vitamin_a, vitamin_c, calcium, iron
        )
        SELECT 
            food_name,
            manufacturer,
            COALESCE(serving_size || ' ' || serving_units, serving_size) as serving_size,
            NULLIF(calories_total, '')::int as calories_total,
            NULLIF(calories_fat, '')::int as calories_fat,
            total_fat,
            saturated_fat,
            cholesterol,
            sodium,
            carb,
            fiber,
            protein,
            vitamin_a,
            vitamin_c,
            calcium,
            iron
        FROM tmp_food_details
        WHERE food_name IS NOT NULL;
        
        -- Удаляем временную таблицу
        DROP TABLE IF EXISTS tmp_food_details;
        
        -- Показываем что получилось
        SELECT COUNT(*) as total_foods FROM flat_foods;
        
