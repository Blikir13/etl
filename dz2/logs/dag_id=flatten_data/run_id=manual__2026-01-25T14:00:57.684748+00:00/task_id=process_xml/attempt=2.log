        -- Очищаем таблицу перед записью
        TRUNCATE TABLE flat_foods;
        
        -- Используем unnest для извлечения всех элементов
        WITH xml_elements AS (
            SELECT 
                unnest(xpath('//food', xml_data::xml)) as food_element
            FROM raw_xml
        ),
        food_data AS (
