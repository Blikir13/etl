        -- Очищаем таблицу перед записью
        TRUNCATE TABLE flat_pets;
        
        -- Используем JSON операторы PostgreSQL
        INSERT INTO flat_pets (name, species, fav_foods, birth_year, photo)
        SELECT 
            pet->>'name' as name,
