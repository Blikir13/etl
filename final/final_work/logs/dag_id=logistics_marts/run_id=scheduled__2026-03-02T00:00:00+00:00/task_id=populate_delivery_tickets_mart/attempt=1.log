        DELETE FROM marts.delivery_tickets_mart
        WHERE snapshot_date = '2026-03-02'::date;

        INSERT INTO marts.delivery_tickets_mart (
            snapshot_date,
            issue_type,
            status,
            tickets_count,
            avg_resolution_time_hours,
            open_tickets_count
        )
        SELECT
            '2026-03-02'::date AS snapshot_date,
            dt.issue_type,
            dt.status,
            COUNT(*) AS tickets_count,
            AVG(
                CASE
                    WHEN dt.resolution_time_seconds IS NOT NULL
                    THEN dt.resolution_time_seconds / 3600.0
                    ELSE NULL
                END
            )::NUMERIC(12, 2) AS avg_resolution_time_hours,
            SUM(
                CASE
                    WHEN dt.status IN ('open', 'in_progress')
                    THEN 1
                    ELSE 0
                END
            ) AS open_tickets_count
        FROM raw.delivery_tickets dt
        WHERE dt.created_at::date <= '2026-03-02'::date
        GROUP BY
            dt.issue_type,
            dt.status;
        
