        DELETE FROM marts.delivery_activity_mart
        WHERE activity_date = '2026-03-02'::date;

        INSERT INTO marts.delivery_activity_mart (
            activity_date,
            user_id,
            deliveries_count,
            avg_delivery_duration_seconds,
            problematic_deliveries_count
        )
        SELECT
            ds.start_time::date AS activity_date,
            ds.user_id,
            COUNT(*) AS deliveries_count,
            AVG(ds.session_duration_seconds)::NUMERIC(12, 2) AS avg_delivery_duration_seconds,
            COALESCE(SUM(
                CASE
                    WHEN de.event_type IN ('error', 'failed', 'delayed')
                    THEN 1
                    ELSE 0
                END
            ), 0) AS problematic_deliveries_count
        FROM raw.delivery_sessions ds
        LEFT JOIN raw.delivery_events de
            ON de.details->>'path' IS NOT NULL
            AND de.timestamp::date = ds.start_time::date
            AND de.event_type IN ('error', 'failed', 'delayed')
        WHERE ds.start_time::date = '2026-03-02'::date
        GROUP BY
            ds.start_time::date,
            ds.user_id;
        
